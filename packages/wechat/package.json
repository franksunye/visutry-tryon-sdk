{
  "name": "@visutry/tryon-wechat",
  "version": "0.2.2",
  "description": "WeChat Mini Program adapter (experimental) for VisuTry SDK: camera, visionkit face tracker, offscreen-canvas renderer.",
  "license": "MIT",
  "keywords": [
    "ar",
    "try-on",
    "glasses",
    "face",
    "face-shape",
    "landmark",
    "weixin",
    "miniprogram",
    "wechat",
    "augmented-reality",
    "virtual-tryon",
    "on-device",
    "privacy",
    "typescript",
    "sdk",
    "visutry"
  ],
  "homepage": "https://github.com/franksunye/visutry-tryon-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/franksunye/visutry-tryon-sdk.git",
    "directory": "packages/wechat"
  },
  "bugs": {
    "url": "https://github.com/franksunye/visutry-tryon-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@visutry/tryon-core": "workspace:*"
  }
}
