{
  "name": "@visutry/tryon-web",
  "version": "1.0.0-beta.0",
  "description": "Web (H5) adapter for VisuTry SDK: getUserMedia camera, MediaPipe FaceLandmarker, Three.js renderer and SDK facade.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "three": ">=0.150.0 <1.0.0",
    "@mediapipe/tasks-vision": ">=0.10.0 <1.0.0"
  },
  "dependencies": {
    "@visutry/tryon-core": "workspace:*"
  },
  "devDependencies": {
    "@mediapipe/tasks-vision": "^0.10.18",
    "@types/three": "^0.170.0",
    "three": "^0.170.0"
  }
}
