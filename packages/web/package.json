{
  "name": "@visutry/tryon-web",
  "version": "0.2.2",
  "description": "Web (H5) adapter for VisuTry SDK: getUserMedia camera, MediaPipe FaceLandmarker, Three.js renderer and SDK facade.",
  "license": "MIT",
  "keywords": [
    "ar",
    "try-on",
    "glasses",
    "face",
    "face-shape",
    "face-analysis",
    "landmark",
    "mediapipe",
    "threejs",
    "webgl",
    "computer-vision",
    "augmented-reality",
    "virtual-tryon",
    "on-device",
    "privacy",
    "h5",
    "typescript",
    "sdk",
    "visutry"
  ],
  "homepage": "https://github.com/franksunye/visutry-tryon-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/franksunye/visutry-tryon-sdk.git",
    "directory": "packages/web"
  },
  "bugs": {
    "url": "https://github.com/franksunye/visutry-tryon-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./analyzer": {
      "types": "./dist/ImageAnalyzer.d.ts",
      "import": "./dist/ImageAnalyzer.js"
    },
    "./overlay": {
      "types": "./dist/overlay/LandmarkOverlay.d.ts",
      "import": "./dist/overlay/LandmarkOverlay.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "three": ">=0.150.0 <1.0.0",
    "@mediapipe/tasks-vision": ">=0.10.0 <1.0.0"
  },
  "dependencies": {
    "@visutry/tryon-core": "workspace:*"
  },
  "devDependencies": {
    "@mediapipe/tasks-vision": "^0.10.18",
    "@types/three": "^0.170.0",
    "three": "^0.170.0"
  }
}
