{
  "name": "@visutry/recommender",
  "version": "0.2.3",
  "description": "Glasses recommendation engine for VisuTry SDK: face-shape x frame matching, millimeter-level size recommendation, preference scoring.",
  "license": "MIT",
  "keywords": [
    "glasses",
    "recommendation",
    "face-shape",
    "frame-matching",
    "sizing",
    "try-on",
    "face-analysis",
    "augmented-reality",
    "virtual-tryon",
    "typescript",
    "sdk",
    "visutry"
  ],
  "homepage": "https://github.com/franksunye/visutry-tryon-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/franksunye/visutry-tryon-sdk.git",
    "directory": "packages/recommender"
  },
  "bugs": {
    "url": "https://github.com/franksunye/visutry-tryon-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@visutry/tryon-core": "workspace:*"
  }
}
