{
  "entryPoints": [
    "packages/core/src/index.ts",
    "packages/web/src/index.ts",
    "packages/recommender/src/index.ts"
  ],
  "tsconfig": "tsconfig.base.json",
  "out": "docs/api",
  "name": "VisuTry SDK API Reference",
